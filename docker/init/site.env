# Uncomment and set to your values if using rsync
#RSYNC_HOST=user@your-server.example.com
#RSYNC_DEST=/path/to/your/web/root/

# Uncomment and set to your values if using S3
#S3_BUCKET=your-s3-bucket

# Uncomment and set to your values if using CloudFront (invalidates cache after deploy)
#CLOUDFRONT_ID=YOUR_CLOUDFRONT_DISTRIBUTION_ID
